# Supabase (create project at supabase.com, run supabase/schema.sql)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin credentials (set strong values in production)
ADMIN_PASSWORD=changeme
ADMIN_SECRET=changeme-long-random-string

# Optional: protect cron endpoint in production
CRON_SECRET=
