# Vercel Blob (create store in Vercel dashboard — auto-injects vars)
# Production uses BLOB_STORE_ID + OIDC; local dev may use BLOB_READ_WRITE_TOKEN.
BLOB_READ_WRITE_TOKEN=

# Admin credentials (set strong values in production)
ADMIN_PASSWORD=changeme
ADMIN_SECRET=changeme-long-random-string

# Optional: protect cron endpoint in production
CRON_SECRET=
